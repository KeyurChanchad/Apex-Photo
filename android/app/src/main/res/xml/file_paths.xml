<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- For camera photos -->
    <external-files-path 
        name="camera_photos" 
        path="Pictures/" />
    
    <!-- For downloaded images -->
    <external-files-path 
        name="downloads" 
        path="Download/" />
    
    <!-- For cache directory (temp images) -->
    <cache-path 
        name="cache" 
        path="." />
    
    <!-- For external cache directory -->
    <external-cache-path 
        name="external_cache" 
        path="." />
    
    <!-- For general file access -->
    <files-path 
        name="files" 
        path="." />
    
    <!-- For external storage access -->
    <external-path 
        name="external" 
        path="." />
</paths>